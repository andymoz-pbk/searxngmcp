[Unit]
Description=SearXNG MCP Server
Documentation=https://github.com/andy/searxngmcp
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/searxngmcp --config /etc/searxngmcp/config.json
Restart=always
RestartSec=5
User=nobody
Group=nogroup
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/etc/searxngmcp

[Install]
WantedBy=multi-user.target
